# ============================================
# COINUP - Environment Variables Example
# ============================================
# Copie este arquivo para .env e preencha com seus dados
# NUNCA commitar o arquivo .env real!

# --------------------------------------------
# Database (MySQL)
# --------------------------------------------
DB_HOST=localhost
DB_NAME=coinup66_coinup
DB_USER=coinup66_usuario
DB_PASS=sua_senha_aqui

# --------------------------------------------
# Blockchain APIs (Alchemy)
# --------------------------------------------
ALCHEMY_ETHEREUM_KEY=sua_chave_aqui
ALCHEMY_BNB_KEY=sua_chave_aqui
ALCHEMY_ARBITRUM_KEY=sua_chave_aqui
ALCHEMY_BASE_KEY=sua_chave_aqui
ALCHEMY_POLYGON_KEY=sua_chave_aqui

# --------------------------------------------
# Preços Cripto (CoinGecko)
# --------------------------------------------
COINGECKO_API_KEY=sua_chave_aqui

# --------------------------------------------
# Benchmarks (Alpha Vantage)
# --------------------------------------------
ALPHA_VANTAGE_API_KEY=sua_chave_aqui

# --------------------------------------------
# Explorers (opcionais)
# --------------------------------------------
ETHERSCAN_API_KEY=sua_chave_aqui
BSCSCAN_API_KEY=sua_chave_aqui
ARBISCAN_API_KEY=sua_chave_aqui
BASESCAN_API_KEY=sua_chave_aqui
POLYGONSCAN_API_KEY=sua_chave_aqui

# --------------------------------------------
# Sessão e Segurança
# --------------------------------------------
SESSION_SECRET=string_aleatoria_segura_aqui
APP_ENV=production
APP_URL=https://coinup.com.br/main
