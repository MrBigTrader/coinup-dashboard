# ============================================
# CoinUp Dashboard - .htaccess Principal
# ============================================

# Ativar reescrita de URL
RewriteEngine On

# Forçar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Definir pasta base como /main
RewriteBase /main/

# ============================================
# SEGURANÇA
# ============================================

# Bloquear acesso direto a arquivos sensíveis
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^\.env\.example">
    Order allow,deny
    Deny from all
</FilesMatch>

# Bloquear acesso a arquivos de configuração
<FilesMatch "\.(sql|log|ini|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Proteger diretórios
<IfModule mod_rewrite.c>
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^src/ - [F,L]
    RewriteRule ^workers/ - [F,L]
</IfModule>

# ============================================
# HEADERS DE SEGURANÇA
# ============================================

# Prevenir clickjacking
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================
# PHP SETTINGS
# ============================================

<IfModule mod_php7.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log /home2/coinup66/public_html/main/logs/php_errors.log
    php_value max_execution_time 300
    php_value memory_limit 256M
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>

# ============================================
# CACHE ESTÁTICO
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# ============================================
# PAGINAS DE ERRO PERSONALIZADAS
# ============================================

ErrorDocument 403 /main/public/error.php?code=403
ErrorDocument 404 /main/public/error.php?code=404
ErrorDocument 500 /main/public/error.php?code=500
